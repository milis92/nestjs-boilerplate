{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_file_path\" | grep -qE '(\\.env|\\.lock$|pnpm-lock)' && echo 'BLOCK: Protected file — .env and lock files should not be edited by Claude' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_file_path\" | grep -qE '\\.ts$' && pnpm prettier --write \"$TOOL_INPUT_file_path\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
