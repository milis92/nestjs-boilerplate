{
  "name": "nestjs-backend-boilerplate",
  "private": true,
  "version": "1.0.0",
  "description": "Production-ready NestJS backend boilerplate with auth, caching, rate limiting, GraphQL, and more",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:cov": "vitest run --project unit --coverage",
    "test:debug": "vitest --inspect-brk --pool forks --poolOptions.forks.singleFork --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:watch": "vitest --project e2e",
    "test:all": "vitest run",
    "db:generate": "bash db-generate.sh",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "docker:up": "docker compose --env-file .env -f docker-compose.yml up -d --wait",
    "docker:down": "docker compose --env-file .env -f docker-compose.yml down"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@dotenvx/dotenvx": "^1.52.0",
    "@keyv/redis": "^5.1.5",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.0.13",
    "@tygra/nestjs-graceful-shutdown": "^2.0.0",
    "@types/express": "^5.0.6",
    "axios": "1.13.5",
    "better-auth": "^1.5.3",
    "cache-manager": "^7.2.7",
    "cacheable": "^2.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "keyv": "^5.5.5",
    "nestjs-pino": "^4.5.0",
    "pg": "^8.16.3",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/node": "^22.19.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^1.0.0-beta.12-a5629fb",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^15.15.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@nestjs/swagger",
      "@scarf/scarf",
      "@swc/core",
      "esbuild"
    ]
  }
}
