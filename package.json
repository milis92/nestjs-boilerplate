{
  "name": "nest-backend",
  "private": true,
  "version": "1.0.0",
  "description": "NEST backend boilerplate",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:migrate": "pnpm build && dotenvx run -- pnpm dlx @better-auth/cli@latest migrate --config dist/infra/auth/better_auth.js",
    "docker:up": "docker compose --env-file .env -f docker-compose.yml up -d --wait",
    "docker:down": "docker compose --env-file .env -f docker-compose.yml down",
    "test:e2e": "dotenvx run -f .env.test -- pnpm docker:test:up && dotenvx run -f .env.test -- jest --config test/jest.config.json; pnpm docker:test:down"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@dotenvx/dotenvx": "^1.51.2",
    "@keyv/redis": "^5.1.5",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.0.13",
    "@tygra/nestjs-graceful-shutdown": "^2.0.0",
    "@types/express": "^5.0.6",
    "axios": "^1.13.2",
    "better-auth": "^1.4.9",
    "cache-manager": "^7.2.7",
    "cacheable": "^2.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "keyv": "^5.5.5",
    "nestjs-pino": "^4.5.0",
    "pg": "^8.16.3",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.9",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^15.15.0",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@nestjs/swagger",
      "@scarf/scarf",
      "@swc/core",
      "esbuild"
    ]
  }
}
