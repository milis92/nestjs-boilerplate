#############################
# Application Configuration #
#############################

# The environment in which the application is running.
# Determines behavior such as error handling verbosity, optimizations, and feature flags.
# Must be one of: development, staging, production, test
NODE_ENV="test"

# The network port number on which the application will listen for incoming HTTP requests.
# Must be a valid port number (1-65535). Ports below 1024 typically require elevated privileges.
APP_PORT=3000

# The base URL prefix prepended to all API routes.
# Useful for versioning, namespacing, or reverse proxy routing.
# Example: "/api" results in routes like /api/health, /api/users
APP_GLOBAL_ROUTE_PREFIX="/api"

# Trust Proxy Configuration
# Configures the 'trust proxy' setting for Express.
# This is important when the app is behind a reverse proxy (e.g., Nginx, Cloudflare).
# Options:
# - true/false: trust all proxies (unsafe if not properly configured) or none (default).
# - string: single IP, CIDR, or special values ('loopback', 'linklocal', 'uniquelocal').
# - comma-separated list: multiple IPs/CIDRs/special values.
# - number: trust the nth hop from the front-facing proxy server.
# Default: false
APP_TRUST_PROXY="loopback"

# CORS Configuration
# A comma-separated list of allowed origins for Cross-Origin Resource Sharing (CORS).
# Specifies which external domains are permitted to make requests to this API.
# Use specific URLs for security (e.g., http://localhost:3000,https://app.example.com)
# or '*' to allow all origins (not recommended for production).
APP_CORS_ORIGINS="http://localhost:3000"

# Logger Configuration
# The minimum severity level of log messages to record.
# Messages below this level will be ignored.
# Levels in order of severity: trace, debug, info, warn, error, fatal
# Use 'trace' for maximum detail, 'info' for production, 'error' for minimal logging.
APP_LOG_LEVEL="trace"

# The destination where log output will be sent.
# Currently has to "console", since other destinations are not implemented yet
APP_LOG_COLLECTOR="console"

#######################
# Cache Configuration #
#######################

# Default Time-to-live (TTL) for cache entries.
# Defines how long cached data will be stored before expiring.
# Format: Human-readable time string (e.g., "1h", "30m", "2d", "1h")
# Supported units: ms (milliseconds), s (seconds), m (minutes), h (hours), d (days)
# Default: 1 hour
CACHE_TTL="1h"

# Maximum number of items to store in the in-memory LRU cache.
# When the limit is reached, the least recently used items will be evicted.
# Default: 5000
CACHE_LRU_SIZE=5000

# Rate Limiter Configuration

# Time window in milliseconds for rate limiting.
# Requests are counted within this time window.
# Default: 60000 (60 seconds)
RATE_LIMIT_TTL=60000

# Maximum number of requests allowed within the TTL window.
# Default: 100 requests per RATE_LIMIT_TTL
RATE_LIMIT_MAX=100

# Duration in milliseconds to block requests after exceeding the limit.
# Default: 60000 (60 seconds)
RATE_LIMIT_BLOCK_DURATION=60000

#######################
# Redis Configuration #
#######################

# The hostname or IP address of the Redis server.
# For Docker/Kubernetes environments, use the service name (e.g., 'redis').
# For local development, use 'localhost'.
REDIS_HOST="localhost"

# The port number on which the Redis server is listening.
# Default Redis port is 6379.
REDIS_PORT=6379

# Password for authenticating with the Redis server (if required).
# Leave empty if Redis does not require authentication.
REDIS_PASSWORD=""

# Enable TLS/SSL connection to Redis.
# Set to 'true' for secure connections, 'false' otherwise.
REDIS_TLS=false

# Whether to reject unauthorized TLS certificates.
# Set to 'true' in production with valid certificates, 'false' for self-signed certificates.
REDIS_REJECT_UNAUTHORIZED=false

# Path to the Certificate Authority (CA) certificate file for TLS connections.
# Leave empty if not using TLS or if using system-trusted certificates.
REDIS_CA=""

# Path to the client private key file for TLS connections.
# Leave empty if not using client certificate authentication.
REDIS_KEY=""

# Path to the client certificate file for TLS connections.
# Leave empty if not using client certificate authentication.
REDIS_CERT=""

# Redis database number for cache storage (0-15).
# Separates cache data from other Redis data.
# Default: 0
REDIS_CACHE_DB=0

# Redis database number for rate limiter storage (0-15).
# Separates rate limiter data from cache and other data.
# Default: 1
REDIS_RATE_LIMITER_DB=1

# Connection timeout in milliseconds.
# How long to wait before timing out when connecting to Redis.
# Default: 10000 (10 seconds)
REDIS_CONNECT_TIMEOUT=10000

############################
# PostgreSQL Configuration #
############################

# NOTE: POSTGRES_HOST and POSTGRES_PORT are intentionally omitted.
# The test connection string is provided via Vitest's provide/inject from vitest-global.setup.ts.

# The name of the default database to create/use.
# Choose an application-specific name.
POSTGRES_DB="test_db"

# The PostgreSQL username with access to the database.
# Default: "postgres"
POSTGRES_USER="test"

# Password for the PostgreSQL user.
# IMPORTANT: PostgreSQL official image requires a non-empty password.
# Change this to a strong, unique value in all environments.
POSTGRES_PASSWORD="test"

# Enable TLS/SSL connection to PostgreSQL.
# Set to 'true' for secure connections, 'false' otherwise.
POSTGRES_SSL=false

# Whether to reject unauthorized TLS certificates.
# Set to 'true' in production with valid certificates, 'false' for self-signed certificates.
# Note: Only applies when POSTGRES_SSL is 'true'.
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

################################
# Authentication Configuration #
################################

# Secret key used for signing and verifying authentication tokens and sessions.
# IMPORTANT: This must be a long, random, and secure string.
# Generate using: openssl rand -base64 32
# Change this to a unique secret value in all environments.
AUTH_SECRET="your-secret-key-change-this-in-production"

# The base URL where the API is accessible.
# Used for constructing callback URLs and redirects in authentication flows.
# Example: http://localhost:3000 for local dev, https://api.example.com for production
AUTH_BASE_URL="http://localhost:${APP_PORT}"

# Comma-separated list of trusted origins for authentication.
# These origins are allowed to initiate authentication flows and receive tokens.
# Should typically match your APP_CORS_ORIGINS for client applications.
# Example: http://localhost:3000,https://app.example.com
AUTH_TRUSTED_ORIGINS="${APP_CORS_ORIGINS}"

# How long (in seconds) before a session expires and the user must re-authenticate.
# Default: 604800 (7 days)
AUTH_SESSION_EXPIRES_IN=604800

# How often (in seconds) the session's expiry is refreshed on active use.
# Default: 86400 (1 day)
AUTH_SESSION_UPDATE_AGE=86400

# The hostname or IP address of the auth database server.
# Allows auth data to be stored in a separate database from the application.
# For Docker/Kubernetes environments, use the service name (e.g., 'postgres').
# For local development, use 'localhost'.
AUTH_DATABASE_HOST="${POSTGRES_HOST}"

# The port number on which the auth database server is listening.
# Default PostgreSQL port is 5432.
AUTH_DATABASE_PORT="${POSTGRES_PORT}"

# The name of the database used for authentication data.
# Can be the same as POSTGRES_DB or a dedicated database for auth isolation.
AUTH_DATABASE_DB="${POSTGRES_DB}"

# The PostgreSQL username with access to the auth database.
AUTH_DATABASE_USER="${POSTGRES_USER}"

# Password for the auth database user.
# Change this to a strong, unique value in all environments.
AUTH_DATABASE_PASSWORD="${POSTGRES_PASSWORD}"

# Enable TLS/SSL connection to the auth database.
# Set to 'true' for secure connections, 'false' otherwise.
AUTH_DATABASE_SSL="${POSTGRES_SSL}"

# Whether to reject unauthorized TLS certificates for the auth database.
# Set to 'true' in production with valid certificates, 'false' for self-signed certificates.
# Note: Only applies when AUTH_DATABASE_SSL is 'true'.
AUTH_DATABASE_SSL_REJECT_UNAUTHORIZED="${POSTGRES_SSL_REJECT_UNAUTHORIZED}"

#########################
# OpenAPI Configuration #
#########################

# Path segment where Swagger UI and JSON are served.
# Default: "api/docs"
DOCS_PATH="${APP_GLOBAL_ROUTE_PREFIX}/docs"

# Title displayed in the Swagger UI.
# Default: "API"
DOCS_TITLE="API"

# Short description shown under the title in Swagger UI.
# Default: "API documentation"
DOCS_DESCRIPTION="API documentation"

# API version string shown in the docs.
# Default: "1.0"
DOCS_VERSION="1.0"

#########################
# GraphQL Configuration #
#########################

# Enable/Disable GraphQL Playground.
# Default: true
GQL_PLAYGROUND=true

# Enable/Disable GraphQL debug mode.
# Default: true
GQL_DEBUG=true

# The path segment where GraphQL API and Playground are served.
# Default: "/graphql"
GQL_PATH="/graphql"

# Enable/Disable GraphQL Introspection.
# Default: true
GQL_INTROSPECTION=true
